fn policy_check(mode: i64) -> i64 {
    let allowed: i64 = mode * 1;
    return allowed;
}

fn heartbeat_emit() -> i64 {
    return 0x4842;
}

fn bastion_init() -> i64 {
    let policy: i64 = policy_check(1);
    let heartbeat: i64 = heartbeat_emit();
    let result: i64 = heartbeat * policy;
    return result;
}
