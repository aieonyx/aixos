fn framebuffer_init() -> i64 {
    return 0x4642;
}

fn sovereign_color() -> i64 {
    return 0x7B4FDB;
}

fn resolution_width() -> i64 {
    return 1280;
}

fn resolution_height() -> i64 {
    return 720;
}

// cursor dimensions for sovereign desktop compositor
fn cursor_width() -> i64 { return 12; }
fn cursor_height() -> i64 { return 20; }
